# See https://help.github.com/articles/ignoring-files/

# Dependencies
/node_modules
/.pnp
.pnp.js

# Production build
/build
/dist

# Tests
/coverage

# Environment & secrets (never commit)
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env*.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log

# OS / IDE
.DS_Store
Thumbs.db
.idea/
*.swp
*.swo

# Editor (keep shared settings if team uses them; ignore local overrides)
.vscode/*
!.vscode/extensions.json

# Vercel
.vercel

# Caches
.eslintcache
.cache
.parcel-cache
.turbo

# Optional local tooling
.cursor/

# Misc
*.tsbuildinfo
