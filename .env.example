# =============================================================================
# Reyansh ERP — Environment Variables (Create React App)
# =============================================================================
# Copy to .env.local for local dev. Set the same REACT_APP_* vars in Vercel.
# CRA requires REACT_APP_ prefix. Restart after changes: npm start
# =============================================================================

# --- Required: Supabase ---
# Dashboard → Project Settings → API
REACT_APP_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
REACT_APP_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_OR_PUBLISHABLE_KEY

# --- Required for production OAuth redirect allowlists (Vercel URL, no trailing slash) ---
REACT_APP_APP_URL=https://your-app.vercel.app

# --- Local development only (optional; defaults to http://localhost:3000) ---
REACT_APP_LOCAL_DEV_ORIGIN=http://localhost:3000

# --- Optional integrations ---
REACT_APP_WHATSAPP_LINK=https://wa.me/

# =============================================================================
# Vercel dashboard (Production + Preview): add all REACT_APP_* keys above.
# Supabase Auth → URL Configuration → Redirect URLs must include REACT_APP_APP_URL
# and http://localhost:3000 for local Google OAuth.
# =============================================================================
